# Struct environment example
# Copy this file to .env and fill in the values you actually use.

# Optional runtime override. When unset, the app uses the project root or the
# platform-specific fallback directory.
STRUCT_RUNTIME_DIR=

# Hugging Face token used by the RAG / embedding layer.
# The app also mirrors this value into HUGGINGFACE_HUB_TOKEN at runtime.
HF_TOKEN=

# DeepSeek provider credentials.
DEEPSEEK_API_KEY=

# OpenRouter provider credentials and metadata.
OPENROUTER_API_KEY=
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_TITLE=